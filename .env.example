# Environment Variables for Fraud Velocity Monitor

# Mapbox API Key for Geographic Visualizations
MAPBOX_API_KEY=your_mapbox_api_key_here

# Data API Key (if required by the backend to fetch external intelligence data)
DATA_API_KEY=your_data_api_key_here

# Backend API URL (for the frontend to communicate with)
# Default is http://localhost:8000 but can be changed for production
NEXT_PUBLIC_API_URL=http://localhost:8000
